## Nord-inspired nano config
## Target: ~/.config/nano/nanorc

set autoindent
set constantshow
set historylog
set indicator
set linenumbers
set mouse
set positionlog
set smarthome
set softwrap
set tabsize 4

## UI colors (Nord-ish, using safe nano color names)
set titlecolor bold,white,black
set statuscolor bold,white,brightblack
set errorcolor bold,white,red
set promptcolor bold,white,brightblack
set minicolor bold,white,black
set keycolor cyan,black
set functioncolor green,black
set numbercolor blue,black
set selectedcolor white,blue
set spotlightcolor black,yellow
set scrollercolor cyan,brightblack
set stripecolor brightblack,black
set guidestripe 80

## Load distro syntax files when available
include "/usr/share/nano/*.nanorc"
