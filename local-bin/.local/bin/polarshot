#!/usr/bin/env bash
set -euo pipefail

DIR="$HOME/Pictures/Screenshots"
mkdir -p "$DIR"

STAMP="$(date +'%Y-%m-%d_%H-%M-%S')"
FILE="$DIR/$STAMP.png"

need() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "Missing command: $1" >&2
        command -v notify-send >/dev/null 2>&1 && notify-send "Screenshot failed" "Missing command: $1"
        exit 1
    }
}

copy_and_notify() {
    wl-copy < "$FILE"
    command -v notify-send >/dev/null 2>&1 && notify-send "Screenshot saved" "$FILE"
    printf '%s\n' "$FILE"
}

need grim
need wl-copy
need hyprctl
need python3

mode="${1:-area}"

case "$mode" in
    full)
        grim "$FILE"
        copy_and_notify
        ;;
    area)
        need slurp
        GEOM="$(slurp)"
        [ -n "$GEOM" ] || exit 0
        grim -g "$GEOM" "$FILE"
        copy_and_notify
        ;;
    active)
        GEOM="$(
            hyprctl activewindow -j | python3 -c '
import json, sys
data = json.load(sys.stdin)
at = data.get("at")
size = data.get("size")
if not at or not size or len(at) != 2 or len(size) != 2:
    raise SystemExit(1)
x, y = at
w, h = size
print(f"{x},{y} {w}x{h}")
'
        )"
        [ -n "$GEOM" ] || exit 1
        grim -g "$GEOM" "$FILE"
        copy_and_notify
        ;;
    *)
        echo "Usage: polarshot {full|area|active}" >&2
        exit 1
        ;;
esac
