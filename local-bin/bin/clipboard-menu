#!/usr/bin/env bash
set -euo pipefail

set +e
selection="$(cliphist list | rofi -dmenu -p 'clipboard')"
rofi_status=$?
set -e

[[ $rofi_status -eq 1 || -z "${selection:-}" ]] && exit 0
[[ $rofi_status -ne 0 && $rofi_status -ne 10 ]] && exit 0

decoded="$(cliphist decode <<<"$selection")"
printf '%s' "$decoded" | wl-copy

if command -v notify-send >/dev/null 2>&1; then
  notify-send "Clipboard" "Entry copied to clipboard"
fi

if [[ $rofi_status -eq 10 ]]; then
  if command -v wtype >/dev/null 2>&1; then
    wtype -M ctrl v -m ctrl
  else
    echo "wtype not found; copied entry but cannot auto-paste." >&2
    if command -v notify-send >/dev/null 2>&1; then
      notify-send "Clipboard" "Copied, but no auto-paste (wtype missing)"
    fi
  fi
fi
