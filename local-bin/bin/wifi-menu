#!/usr/bin/env bash
set -euo pipefail

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing command: $1" >&2
    exit 1
  fi
}

require_cmd nmcli
require_cmd rofi

notify() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "Wi-Fi" "$1"
  fi
}

terminal="${TERMINAL:-alacritty}"

wifi_state() {
  nmcli radio wifi 2>/dev/null || echo "unknown"
}

active_connection() {
  nmcli -t -f NAME,DEVICE,TYPE connection show --active 2>/dev/null | awk -F: '$3=="wifi"{print $1 " [" $2 "]"; exit}'
}

show_status() {
  local state active
  state="$(wifi_state)"
  active="$(active_connection || true)"
  printf 'Wi-Fi: %s\nActive: %s\n' "${state}" "${active:-none}" | rofi -dmenu -p "wifi status" >/dev/null || true
}

open_connect_ui() {
  if command -v nmtui >/dev/null 2>&1; then
    nohup "${terminal}" -e nmtui connect >/dev/null 2>&1 &
    exit 0
  fi

  if command -v nm-connection-editor >/dev/null 2>&1; then
    nohup nm-connection-editor >/dev/null 2>&1 &
    exit 0
  fi

  notify "No NetworkManager UI found"
  exit 1
}

toggle_wifi() {
  local state
  state="$(wifi_state)"
  if [[ "${state}" == "enabled" ]]; then
    nmcli radio wifi off
    notify "Wi-Fi disabled"
  else
    nmcli radio wifi on
    notify "Wi-Fi enabled"
  fi
}

choice="$(printf 'connect or switch network\ntoggle wifi\nrescan\nstatus\n' | rofi -dmenu -p 'wifi')"

case "${choice:-}" in
  "connect or switch network")
    open_connect_ui
    ;;
  "toggle wifi")
    toggle_wifi
    ;;
  "rescan")
    nmcli device wifi rescan >/dev/null 2>&1 || true
    notify "Wi-Fi rescan started"
    ;;
  "status")
    show_status
    ;;
esac
