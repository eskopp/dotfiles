#!/usr/bin/env bash
set -euo pipefail

BG="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/background.png"

[[ -f "$BG" ]] || {
  echo "Wallpaper not found: $BG" >&2
  exit 1
}

if command -v hyprctl >/dev/null 2>&1; then
  while IFS= read -r MON; do
    [[ -n "$MON" ]] || continue
    hyprctl hyprpaper wallpaper "$MON,$BG,cover"
  done < <(hyprctl monitors | awk '/Monitor/{print $2}')
fi

printf '%s\n' "$BG"
