#!/usr/bin/env bash
set -euo pipefail

if [[ "${XDG_VTNR:-}" != "1" && -n "${DISPLAY:-}" ]]; then
  echo "Start this from a TTY."
  exit 1
fi

if command -v /usr/bin/start-hyprland >/dev/null 2>&1; then
  exec /usr/bin/start-hyprland "$@"
elif command -v Hyprland >/dev/null 2>&1; then
  exec Hyprland "$@"
else
  echo "Neither /usr/bin/start-hyprland nor Hyprland is available in PATH." >&2
  exit 1
fi
