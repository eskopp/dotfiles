#!/usr/bin/env bash
set -euo pipefail

LC_ALL=C
state_dir="${XDG_RUNTIME_DIR:-/tmp}"
state_file="${state_dir}/waybar-net-speed.state"

get_iface() {
  ip route get 1.1.1.1 2>/dev/null | awk '/dev/ {for (i=1;i<=NF;i++) if ($i=="dev") {print $(i+1); exit}}'
}

read_bytes() {
  local iface="$1"
  local rx_file="/sys/class/net/${iface}/statistics/rx_bytes"
  local tx_file="/sys/class/net/${iface}/statistics/tx_bytes"

  [[ -r "${rx_file}" && -r "${tx_file}" ]] || return 1
  read -r rx <"${rx_file}"
  read -r tx <"${tx_file}"
  printf '%s %s\n' "${rx}" "${tx}"
}

human_rate() {
  awk -v bps="$1" '
    BEGIN {
      split("B/s KB/s MB/s GB/s", u, " ")
      i=1
      while (bps >= 1024 && i < 4) { bps/=1024; i++ }
      if (bps >= 100) printf "%.0f %s", bps, u[i]
      else printf "%.1f %s", bps, u[i]
    }
  '
}

iface="$(get_iface || true)"
if [[ -z "${iface}" ]]; then
  echo " 0 KB/s   0 KB/s"
  exit 0
fi

if ! read_vals="$(read_bytes "${iface}")"; then
  echo " 0 KB/s   0 KB/s"
  exit 0
fi

read -r rx_now tx_now <<<"${read_vals}"
ts_now="$(date +%s%N)"

rx_rate=0
tx_rate=0

if [[ -r "${state_file}" ]]; then
  read -r ts_prev rx_prev tx_prev iface_prev <"${state_file}" || true
  if [[ -n "${ts_prev:-}" && -n "${rx_prev:-}" && -n "${tx_prev:-}" && "${iface_prev:-}" == "${iface}" ]]; then
    dt=$((ts_now - ts_prev))
    if (( dt > 0 && rx_now >= rx_prev && tx_now >= tx_prev )); then
      rx_rate=$(((rx_now - rx_prev) * 1000000000 / dt))
      tx_rate=$(((tx_now - tx_prev) * 1000000000 / dt))
    fi
  fi
fi

printf '%s %s %s %s\n' "${ts_now}" "${rx_now}" "${tx_now}" "${iface}" >"${state_file}"

rx_h="$(human_rate "${rx_rate}")"
tx_h="$(human_rate "${tx_rate}")"

printf ' %s   %s\n' "${rx_h}" "${tx_h}"
