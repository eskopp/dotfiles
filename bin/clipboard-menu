#!/usr/bin/env bash
set -euo pipefail

rofi_cmd=(rofi -dmenu -i -p 'clipboard' -mesg 'Enter: kopieren  |  Alt+Enter: kopieren + einfügen' -kb-custom-1 'Alt+Return')
selection="$(cliphist list | "${rofi_cmd[@]}")"
rofi_status=$?

# 0: normal accept (copy), 10: custom-1 (copy + paste)
if [[ $rofi_status -ne 0 && $rofi_status -ne 10 ]]; then
  exit 0
fi

[[ -n "${selection:-}" ]] || exit 0

decoded="$(cliphist decode <<<"$selection")"
printf '%s' "$decoded" | wl-copy

if command -v notify-send >/dev/null 2>&1; then
  notify-send "Clipboard" "Eintrag in Zwischenablage kopiert"
fi

if [[ $rofi_status -eq 10 ]]; then
  if command -v wtype >/dev/null 2>&1; then
    # Paste into currently focused window.
    wtype -M ctrl v -m ctrl
  else
    echo "wtype not found; copied entry but cannot auto-paste." >&2
    if command -v notify-send >/dev/null 2>&1; then
      notify-send "Clipboard" "Kopiert, aber kein Auto-Paste (wtype fehlt)"
    fi
  fi
fi
