  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "comment",
          "punctuation.definition.comment"
        ],
        "settings": {
          "foreground": "#616E88",
          "fontStyle": "italic"
        }
      },
      {
        "scope": [
          "keyword",
          "storage",
          "keyword.control"
        ],
        "settings": {
          "foreground": "#81A1C1"
        }
      },
      {
        "scope": [
          "string",
          "punctuation.definition.string"
        ],
        "settings": {
          "foreground": "#A3BE8C"
        }
      },
      {
        "scope": [
          "constant.numeric",
          "constant.language",
          "constant.character"
        ],
        "settings": {
          "foreground": "#B48EAD"
        }
      },
      {
        "scope": [
          "entity.name.function",
          "support.function",
          "meta.function-call"
        ],
        "settings": {
          "foreground": "#88C0D0"
        }
      },
      {
        "scope": [
          "entity.name.type",
          "entity.name.class",
          "support.type"
        ],
        "settings": {
          "foreground": "#8FBCBB"
        }
      },
      {
        "scope": [
          "variable",
          "identifier"
        ],
        "settings": {
          "foreground": "#D8DEE9"
        }
      },
      {
        "scope": [
          "invalid",
          "invalid.illegal"
        ],
        "settings": {
          "foreground": "#ECEFF4",
          "background": "#BF616A"
        }
      }
    ]
  },
  "editor.semanticTokenColorCustomizations": {
    "enabled": true,
    "rules": {
      "parameter": "#D8DEE9",
      "property": "#8FBCBB",
      "variable.readonly": "#EBCB8B",
      "function": "#88C0D0",
      "method": "#88C0D0",
      "class": "#8FBCBB",
      "type": "#8FBCBB",
      "enum": "#B48EAD",
      "interface": "#8FBCBB",
      "namespace": "#81A1C1"
    }
  },
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "terminal.integrated.hideOnStartup": "always",
  "terminal.integrated.hideOnLastClosed": false,
  "terminal.integrated.enablePersistentSessions": true,
  "terminal.integrated.defaultLocation": "view",
  "window.openFilesInNewWindow": "on",
  "chat.agent.enabled": false,
  "chat.checkpoints.enabled": false,
  "chat.customAgentInSubagent.enabled": false,
  "chat.editing.confirmEditRequestRemoval": false,
  "telemetry.feedback.enabled": false,
  "editor.formatOnSave": true,
  "editor.autoIndentOnPasteWithinString": false,
  "window.newWindowProfile": "Default",
  "window.titleBarStyle": "custom",
  "workbench.secondarySideBar.defaultVisibility": "hidden"
}
