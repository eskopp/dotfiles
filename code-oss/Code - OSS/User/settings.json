{
  "window.autoDetectColorScheme": false,
  "workbench.preferredDarkColorTheme": "Berserk Eclipse",
  "workbench.startupEditor": "none",
  "window.commandCenter": false,
  "breadcrumbs.enabled": true,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "selection",
  "editor.guides.indentation": true,
  "editor.guides.highlightActiveIndentation": true,
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "off",
  "editor.smoothScrolling": true,
  "editor.fontLigatures": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.stickyScroll.enabled": false,
  "workbench.iconTheme": "vs-seti",
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.cursorBlinking": false,
  "terminal.integrated.tabs.enabled": false,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "terminal.integrated.hideOnStartup": "always",
  "terminal.integrated.hideOnLastClosed": false,
  "terminal.integrated.enablePersistentSessions": true,
  "terminal.integrated.defaultLocation": "view",
  "window.openFilesInNewWindow": "on",
  "chat.agent.enabled": false,
  "chat.checkpoints.enabled": false,
  "chat.customAgentInSubagent.enabled": false,
  "chat.editing.confirmEditRequestRemoval": false,
  "telemetry.feedback.enabled": false,
  "editor.autoIndentOnPasteWithinString": false,
  "window.newWindowProfile": "Default",
  "window.titleBarStyle": "custom",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "workbench.colorTheme": "Berserk Eclipse"
}
